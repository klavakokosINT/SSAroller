local function click(obj)
    if obj and obj.Visible and obj.AbsoluteSize.X > 0 then
        local p = obj.AbsolutePosition + obj.AbsoluteSize/2
        local inset = GuiService:GetGuiInset()
        local targetX = p.X
        local targetY = p.Y + inset.Y
        
        VIM:SendMouseButtonEvent(targetX, targetY, 0, true, game, 1)
        task.wait(0.04)
        VIM:SendMouseButtonEvent(targetX, targetY, 0, false, game, 1)
    end
end

local function getStatValueFromText(text, statName)
    for line in string.gmatch(text, "[^\r\n]+") do
        if statName == "Pollen" then
            if line:find("Pollen") and not (line:find("Blue") or line:find("Red") or line:find("White") or line:find("Gather")) then
                local val = line:match("(%d+)")
                if val then return tonumber(val) end
            end
        else
            if line:find(statName) then
                local val = line:match("(%d+)")
                if val then return tonumber(val) end
            end
        end
    end
    return 0
end

-- [ОСНОВНОЙ ДИНАМИЧЕСКИЙ ПОТОК]
task.spawn(function()
    log("KlavaKokos V1.0 загружен успешно.")
    while true do
        task.wait(currentLoopWait) -- Скорость цикла зависит от настройки
        if not running then continue end
        
        local gameGui = PlayerGui:FindFirstChild("ScreenGui")
        if not gameGui then continue end
        
        local rewards = gameGui:FindFirstChild("RewardsPopUp")
        local msgBox = gameGui:FindFirstChild("MessageBox")
        local qBox = gameGui:FindFirstChild("QuestionBox")
        
        local isAmuletOpen = rewards and rewards.Visible
        local isMsgVisible = msgBox and msgBox.Visible
        local isQVisible = qBox and qBox.Visible
        local isDialogOpen = isMsgVisible or isQVisible
        
        -- ШАГ 1: Финальное диалоговое окно ПОВЕРХ окна амулета
        if isAmuletOpen and isDialogOpen then
            if isMsgVisible then
                local yesBtn = msgBox:FindFirstChild("Box") and msgBox.Box:FindFirstChild("YesButton")
                if yesBtn and yesBtn.Visible then
                    log("Финал: Успешно экипирую новый идеальный амулет!")
                    click(yesBtn)
                    running = false
                    StartBtn.Text = "START ROLL"
                    StartBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
                    StartBtn.TextColor3 = Color3.fromRGB(15, 15, 15)
                    task.wait(currentActionWait)
                end
            elseif isQVisible then
                local yesBtn = qBox:FindFirstChild("Box") and qBox.Box:FindFirstChild("YesButton")
                if yesBtn and yesBtn.Visible then
                    log("Финал: Успешно экипирую новый идеальный амулет!")
                    click(yesBtn)
                    running = false
                    StartBtn.Text = "START ROLL"
                    StartBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
                    StartBtn.TextColor3 = Color3.fromRGB(15, 15, 15)
                    task.wait(currentActionWait)
                end
            end
            continue
        end
        
        -- ШАГ 2: Диалоговое окно БЕЗ амулета (Стартовое подтверждение траты меда)
        if isDialogOpen and not isAmuletOpen then
            if isMsgVisible then
                local yesBtn = msgBox:FindFirstChild("Box") and msgBox.Box:FindFirstChild("YesButton")
                if yesBtn and yesBtn.Visible then log("Старт: Подтверждаю покупку ролла"); click(yesBtn) task.wait(currentActionWait) end
            elseif isQVisible then
                local yesBtn = qBox:FindFirstChild("Box") and qBox.Box:FindFirstChild("YesButton")
                if yesBtn and yesBtn.Visible then log("Старт: Подтверждаю покупку ролла"); click(yesBtn) task.wait(currentActionWait) end
            end
            continue
        end
        
        -- ШАГ 3: Ничего не открыто, нажимаем ActivateButton
        if not isAmuletOpen and not isDialogOpen then
            local activateBtn = gameGui:FindFirstChild("ActivateButton")
            if activateBtn and activateBtn.Visible then
                log("Клик по ActivateButton (Запуск ролла)")
                click(activateBtn)
                task.wait(currentActionWait)
            end
            continue
        end
        
        -- ШАГ 4: Сверка критериев амулета
        if isAmuletOpen and not isDialogOpen then
            local amuletFrame = rewards:FindFirstChild("AmuletFrame")
            local infoNew = amuletFrame and amuletFrame:FindFirstChild("InfoNew")
            
            local acceptBtn = rewards:FindFirstChild("YesButton")
            local declineBtn = rewards:FindFirstChild("NoButton") or rewards:FindFirstChild("BoxColorRed")
            
            if infoNew and infoNew.Text ~= "" and infoNew.Text ~= "Label" and acceptBtn and acceptBtn.Visible then
                local passed = true
                
                for stat, minVal in pairs(StatRequirements) do
                    if minVal > 0 then
                        local rolledValue = getStatValueFromText(infoNew.Text, stat)
                        if rolledValue < minVal then
                            passed = false
                            log("Мимо: " .. stat .. " (" .. rolledValue .. " < " .. minVal .. ")")
                            break
                        end
                    end
                end
                
                if passed then
                    for name, enabled in pairs(SelectedPassives) do
                        if enabled and not infoNew.Text:find(name) then 
                            passed = false 
                            log("Нет нужной пассивки: " .. name)
                            break 
                        end
                    end
                end
                
                if passed then
                    log("УСПЕХ! Амулет подходит. Нажимаю Claim. Жду финальное окно...")
                    click(acceptBtn)
                    task.wait(currentActionWait)
                else
                    log("Статы плохие. Пропускаю ролл...")
                    click(declineBtn)
                    task.wait(currentActionWait + 0.2) -- Небольшой безопасный зазор на закрытие Gui
                end
            end
        end
    end
end)
